# TuShare API Token
TUSHARE_TOKEN=e7b6467864c4c10088f0105f80fc1bbdb66e792e8a82720346b0e6ee

# Rate limiting settings
AKSHARE_RATE_LIMIT=10
TUSHARE_RATE_LIMIT=5

# Cache settings
CACHE_ENABLED=true
CACHE_TTL=300

# Proxy (optional; leave empty to disable. Stage2 会自动检测不可用代理并切换直连)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Stage2 Tavily / DeepSeek
TAVILY_API_KEY=your-tavily-key
DEEPSEEK_API_KEY=your-deepseek-key
# STAGE2_SEARCH_BACKEND 已弃用，请用 CLI 参数 --fund-flow-backend / --extraction-backend

# Python path (方便本地直接运行脚本)
PYTHONPATH=.
